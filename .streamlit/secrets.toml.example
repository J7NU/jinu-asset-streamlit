# Streamlit Cloud Secrets — example
# 실제 배포 시 Streamlit Cloud 콘솔의 "Advanced settings > Secrets"에
# 아래 형식 그대로 paste. 본 파일은 양식만 — 실값 commit 금지.
#
# Supabase Dashboard > Settings > API 에서 값 복사.

SUPABASE_URL = "https://<your-project-ref>.supabase.co"
SUPABASE_ANON_KEY = "<your-anon-public-key>"

# 옵션: 진우 본인 UUID (Authentication > Users 에서 복사)
# 매직링크 redirect 디버그용. 평시에는 auth.uid()로 자동 충족.
# OWNER_ID = "<your-auth-user-uuid>"
